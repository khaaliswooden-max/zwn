# ZWM API (indexer backend)
NEXT_PUBLIC_ZWM_API_URL=http://localhost:3001
NEXT_PUBLIC_ZWM_GRAPHQL_URL=http://localhost:4000/graphql

# Resend (email notifications for /build access requests)
RESEND_API_KEY=re_xxxxxxxxxxxx
NOTIFICATION_EMAIL=khaaliswooden@gmail.com

# Admin secret — must match ADMIN_SECRET in the zuup-zwm-indexer
# Required for the /api/admin/generate-key proxy route
ADMIN_SECRET=change-me-before-production
